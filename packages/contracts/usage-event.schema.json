{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://token-tide.local/schemas/usage-event.v1.json",
  "title": "Token Tide Usage Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_event_id",
    "tool",
    "provider",
    "observed_model",
    "occurred_at",
    "input_tokens",
    "output_tokens",
    "cache_read_tokens",
    "cache_write_tokens",
    "precision",
    "parser_version"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "source_event_id": { "type": "string", "minLength": 8, "maxLength": 200 },
    "tool": { "type": "string", "minLength": 1, "maxLength": 80 },
    "provider": { "type": "string", "minLength": 1, "maxLength": 80 },
    "observed_model": { "type": "string", "minLength": 1, "maxLength": 160 },
    "canonical_model_id": { "type": ["string", "null"], "maxLength": 160 },
    "pricing_context": { "type": ["string", "null"], "maxLength": 80 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "input_tokens": { "type": "integer", "minimum": 0 },
    "output_tokens": { "type": "integer", "minimum": 0 },
    "cache_read_tokens": { "type": "integer", "minimum": 0 },
    "cache_write_tokens": { "type": "integer", "minimum": 0 },
    "request_count": { "type": "integer", "minimum": 0 },
    "precision": { "enum": ["A", "B", "C", "D"] },
    "parser_version": { "type": "string", "minLength": 1, "maxLength": 80 }
  }
}
